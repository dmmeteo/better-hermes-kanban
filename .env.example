HERMES_API_URL=https://bhk.dmmeteo.dev

# Option A — Basic Auth (default, works against bhk.dmmeteo.dev)
HERMES_BASIC_USER=
HERMES_BASIC_PASS=

# Option B — dashboard session auth (use when HERMES_API_URL points at
# her.dmmeteo.dev, which rejects Basic and only accepts hermes_session cookie
# + x-hermes-session-token). Grab both from a logged-in DevTools session.
# When both are set they take precedence over Basic Auth.
HERMES_SESSION_COOKIE=
HERMES_SESSION_TOKEN=
